{
  "name": "travel-hub",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:logs": "tsx watch src/log-server/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "biome lint --write src",
    "format": "biome format --write src",
    "check": "biome check --write --unsafe src",
    "create-indexes": "tsx docs/create-indexes.ts",
    "create-db": "tsx docs/create-db.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@hono/prometheus": "^1.0.1",
    "dotenv": "^16.5.0",
    "hono": "^4.7.8",
    "mongodb": "^6.16.0",
    "neo4j-driver": "^5.28.1",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^20.11.17",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}
